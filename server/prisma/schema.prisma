// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// User
// =============================================
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String?  @unique
  displayName  String?
  avatarUrl    String?
  bio          String?
  passwordHash String?  // For email/password auth
  provider     String?  // 'google' | 'github' | null for email/password
  providerId   String?  // OAuth provider user ID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Portfolio Customization
  portfolioTheme    String   @default("dark") // 'dark' | 'light' | 'neon'
  portfolioTagline  String?
  portfolioSections Json?    // Array of visible sections e.g., ["hero", "platforms", "blogs"]

  // Relations
  refreshTokens  RefreshToken[]
  linkedAccounts LinkedAccount[]
  snippets       Snippet[]
  followers      Follows[]       @relation("followers")
  following      Follows[]       @relation("following")
  activities     ActivityEvent[]
  posts          Post[]
  comments       Comment[]
  postVotes      PostVote[]
  bookmarks      Bookmark[]
  focusSessions  FocusSession[]
  conversations  ConversationParticipant[]
  messages       Message[]
  battleMatches  BattlePlayer[]


  @@unique([provider, providerId])
  @@map("users")
}

// =============================================
// Refresh Tokens (for JWT rotation)
// =============================================
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================
// Linked Platform Accounts (Multi-ID)
// =============================================
model LinkedAccount {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String   // 'codeforces' | 'leetcode' | 'codechef' | 'gfg'
  handle    String   // The platform username/handle
  label     String?  // Custom label: 'Main', 'Practice', etc.
  isPrimary Boolean  @default(false)
  lastSync  DateTime?
  data      Json?    // Cached platform data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform, handle])
  @@index([userId])
  @@map("linked_accounts")
}

// =============================================
// Algorithm Snippets (Vault)
// =============================================
model Snippet {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  code      String
  language  String   // 'cpp', 'python', 'java', etc.
  category  String?  // 'Segment Tree', 'DSU', 'Dijkstra', etc.
  tags      String[] // Array of string tags
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("snippets")
}

// =============================================
// Social / Followers
// =============================================
model Follows {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// =============================================
// Activity Feed Events
// =============================================
model ActivityEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'NEW_LINK_ACCOUNT', 'RATING_UP', 'MILESTONE', etc.
  metadata  Json     // Arbitrary JSON (platform, handles, old/new values)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activity_events")
}

// =============================================
// Blog Posts
// =============================================
model Post {
  id          String    @id @default(uuid())
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  slug        String    @unique
  content     Json                       // TipTap JSON document
  excerpt     String?
  type        String    @default("article") // 'article' | 'editorial' | 'discussion' | 'interview'
  tags        String[]
  status      String    @default("draft")   // 'draft' | 'published'
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  comments    Comment[]
  votes       PostVote[]
  bookmarks   Bookmark[]

  @@index([authorId])
  @@index([status, publishedAt])
  @@index([type])
  @@map("posts")
}

// =============================================
// Threaded Comments
// =============================================
model Comment {
  id        String    @id @default(uuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("replies")
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

// =============================================
// Post Votes (Upvotes)
// =============================================
model PostVote {
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, postId])
  @@map("post_votes")
}

// =============================================
// Bookmarks
// =============================================
model Bookmark {
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, postId])
  @@map("bookmarks")
}

// =============================================
// Focus Sessions (Pomodoro)
// =============================================
model FocusSession {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime
  duration    Int      // Duration actually focused in seconds
  task        String?  // Optional linked problem or task description
  status      String   @default("completed") // 'completed' | 'interrupted'

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([startTime])
  @@map("focus_sessions")
}

// =============================================
// Chat & Messaging
// =============================================
model Conversation {
  id        String   @id @default(uuid())
  type      String   @default("private") // "private" | "group" | "channel"
  name      String?  // For channels/groups
  slug      String?  @unique // For global channels like 'general'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
  battleMatch  BattleMatch?

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

// =============================================
// CF Battle Arena
// =============================================
model BattleMatch {
  id             String        @id @default(uuid())
  problemId      String        // e.g., "1512-A"
  problemName    String
  problemLink    String
  difficulty     Int?          // e.g., 800
  tags           String[]
  status         String        @default("WAITING") // WAITING, STARTING, IN_PROGRESS, COMPLETED, CANCELLED
  winnerId       String?       
  startTime      DateTime?
  endTime        DateTime?
  duration       Int           @default(60) // in minutes
  createdAt      DateTime      @default(now())
  conversationId String?       @unique
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  players        BattlePlayer[]

  @@map("battle_matches")
}

model BattlePlayer {
  id        String      @id @default(uuid())
  matchId   String
  userId    String
  cfHandle  String?     // Built for selecting between multiple linked CF accounts
  joinedAt  DateTime    @default(now())

  match     BattleMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@map("battle_players")
}

